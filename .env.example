# AWS
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# DynamoDB Tables
DYNAMODB_RAW_POSTS_TABLE=socialpulse_raw_posts
DYNAMODB_CLEANED_POSTS_TABLE=socialpulse_cleaned_posts
DYNAMODB_TRENDS_TABLE=socialpulse_trends
DYNAMODB_SENTIMENT_TABLE=socialpulse_sentiment
DYNAMODB_FACT_CHECKS_TABLE=socialpulse_fact_checks
DYNAMODB_PROPAGATION_TABLE=socialpulse_propagation

# Reddit API
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=SocialPulseAI/1.0

# X (Twitter) API
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret
X_BEARER_TOKEN=your_x_bearer_token

# Google Fact Check API
GOOGLE_FACT_CHECK_API_KEY=your_google_fact_check_api_key

# ClaimBuster API
CLAIMBUSTER_API_KEY=your_claimbuster_api_key

# App Settings
APP_ENV=development
DEBUG=true
API_RATE_LIMIT=100
API_KEY_SECRET=your_secret_key_for_jwt

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
